{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Thulirix Backend (Spring Boot)",
      "runtimeExecutable": "C:/Users/sathy/.maven/maven-3.9.12/bin/mvn.cmd",
      "runtimeArgs": [
        "spring-boot:run",
        "-f", "C:/Users/sathy/thulirix/backend/pom.xml",
        "-DDB_PORT=5432",
        "-DDB_USER=postgres",
        "-DDB_PASS=admin"
      ],
      "port": 6001
    },
    {
      "name": "Thulirix Frontend (Vite / React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix", "C:/Users/sathy/thulirix/frontend",
        "run", "dev"
      ],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "Thulirix Infrastructure (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "compose",
        "-f", "C:/Users/sathy/thulirix/docker-compose.yml",
        "up",
        "--build"
      ],
      "port": 80
    },
    {
      "name": "Thulirix DB Only (PostgreSQL via Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "compose",
        "-f", "C:/Users/sathy/thulirix/docker-compose.yml",
        "up", "postgres", "redis"
      ],
      "port": 5432
    }
  ]
}
